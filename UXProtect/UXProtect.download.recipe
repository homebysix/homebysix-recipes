<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Download and unpack the latest version of UXProtect, which provides the missing UI to Apple's built-in XProtect and extends its malware detection/scanning capabilities. Adapted from the deprecated autopkg/zentral-recipes UXProtect recipe, with thanks to Zentral.</string>
	<key>Identifier</key>
	<string>com.github.homebysix.download.UXProtect</string>
	<key>Input</key>
	<dict>
		<key>DL_URL</key>
		<string>https://digitasecurity.com/download/uxprotect/</string>
		<key>NAME</key>
		<string>UXProtect</string>
		<key>RE_PATTERN</key>
		<string>(?P&lt;dl_filename&gt;(UXProtect(\d*\.?)*).zip)</string>
		<key>SEARCH_URL</key>
		<string>https://digitasecurity.com/uxprotect/</string>
	</dict>
	<key>MinimumVersion</key>
	<string>0.6.0</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>%RE_PATTERN%</string>
				<key>result_output_var_name</key>
				<string>dl_filename</string>
				<key>url</key>
				<string>%SEARCH_URL%</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>CHECK_FILESIZE_ONLY</key>
				<true/>
				<key>url</key>
				<string>%DL_URL%%dl_filename%</string>
			</dict>
			<key>Processor</key>
			<string>URLDownloader</string>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>archive_path</key>
				<string>%pathname%</string>
				<key>destination_path</key>
				<string>%RECIPE_CACHE_DIR%/unpacked/</string>
				<key>purge_destination</key>
				<true/>
			</dict>
			<key>Processor</key>
			<string>Unarchiver</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>input_path</key>
				<string>%RECIPE_CACHE_DIR%/unpacked/UXProtect.app</string>
				<key>requirement</key>
				<string>anchor apple generic and identifier "com.digitasecurity.UXProtect" and (certificate leaf[field.1.2.840.113635.100.6.1.9] /* exists */ or certificate 1[field.1.2.840.113635.100.6.2.6] /* exists */ and certificate leaf[field.1.2.840.113635.100.6.1.13] /* exists */ and certificate leaf[subject.OU] = S62KCC4ZPU)</string>
			</dict>
			<key>Processor</key>
			<string>CodeSignatureVerifier</string>
		</dict>
	</array>
</dict>
</plist>
